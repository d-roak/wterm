{
  "name": "@droak/wterm",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/wterm.js",
  "module": "./dist/wterm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wterm.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "homepage": "https://wterm.droak.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-roak/wterm"
  },
  "keywords": [
    "tui",
    "react",
    "terminal-ui",
    "command-palette",
    "monospace"
  ],
  "description": "TUI components for React. Monospace, box-drawing, keyboard-first, with mouse support.",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prebuild": "cp ../../README.md . && cp ../../LICENSE .",
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "cmdk": "^1.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
